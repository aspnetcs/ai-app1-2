{
  "name": "uni-preset-vue",
  "version": "0.0.0",
  "scripts": {
    "postinstall": "weapp-tw patch",
    "dev:custom": "uni",
    "dev:h5": "concurrently -n tw,uni -c blue,green \"node ./scripts/run-tailwindcss.mjs -i ./src/styles/tailwind.css -o ./src/styles/tailwind-compiled.css --watch\" \"uni -p h5\"",
    "tailwind:build": "node ./scripts/run-tailwindcss.mjs -i ./src/styles/tailwind.css -o ./src/styles/tailwind-compiled.css --minify",
    "dev:h5:ssr": "uni --ssr",
    "dev:mp-alipay": "uni -p mp-alipay",
    "dev:mp-baidu": "uni -p mp-baidu",
    "dev:mp-jd": "uni -p mp-jd",
    "dev:mp-kuaishou": "uni -p mp-kuaishou",
    "dev:mp-lark": "uni -p mp-lark",
    "dev:mp-qq": "uni -p mp-qq",
    "dev:mp-toutiao": "uni -p mp-toutiao",
    "dev:mp-harmony": "uni -p mp-harmony",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:mp-xhs": "uni -p mp-xhs",
    "dev:quickapp-webview": "uni -p quickapp-webview",
    "dev:quickapp-webview-huawei": "uni -p quickapp-webview-huawei",
    "dev:quickapp-webview-union": "uni -p quickapp-webview-union",
    "build:custom": "npm run verify:vue-stack && npm run tailwind:build && uni build",
    "build:h5": "npm run verify:vue-stack && npm run tailwind:build && uni build -p h5",
    "build:h5:ssr": "uni build --ssr",
    "build:mp-alipay": "uni build -p mp-alipay",
    "build:mp-baidu": "uni build -p mp-baidu",
    "build:mp-jd": "uni build -p mp-jd",
    "build:mp-kuaishou": "uni build -p mp-kuaishou",
    "build:mp-lark": "uni build -p mp-lark",
    "build:mp-qq": "uni build -p mp-qq",
    "build:mp-toutiao": "uni build -p mp-toutiao",
    "build:mp-harmony": "uni build -p mp-harmony",
    "build:mp-weixin": "npm run verify:vue-stack && npm run tailwind:build && uni build -p mp-weixin && node ./scripts/sanitize-mp-weixin-wxss.mjs",
    "build:mp-xhs": "uni build -p mp-xhs",
    "build:quickapp-webview": "uni build -p quickapp-webview",
    "build:quickapp-webview-huawei": "uni build -p quickapp-webview-huawei",
    "build:quickapp-webview-union": "uni build -p quickapp-webview-union",
    "verify:vue-stack": "node ./scripts/verify-vue-stack.mjs",
    "verify:console-compliance": "node ./scripts/verify-console-compliance.mjs",
    "verify:glyph-compliance": "node ./scripts/verify-glyph-compliance.mjs",
    "verify:h5-fontsize-lock": "node ./scripts/verify-h5-fontsize-lock.mjs",
    "verify:shared-h5-rpx": "node ./scripts/verify-shared-h5-rpx.mjs",
    "verify:h5-output": "node ./scripts/verify-h5-output.mjs",
    "verify:mp-weixin-output": "node ./scripts/verify-mp-weixin-output.mjs",
    "e2e:prepare": "npm run tailwind:build && npm run build:h5",
    "e2e:serve": "node ./scripts/serve-h5-dist.mjs 41880",
    "type-check": "npm run verify:vue-stack && vue-tsc --noEmit",
    "test:e2e": "npm run e2e:prepare && playwright test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-harmony": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-plus": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-baidu": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-harmony": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-jd": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-lark": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-qq": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-xhs": "3.0.0-4080420251103001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-4080420251103001",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.4",
    "mermaid": "^10.9.5",
    "mp-html": "^2.5.2",
    "pinia": "^3.0.4",
    "vue": "3.5.30",
    "vue-i18n": "^9.1.9"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080420251103001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/runtime-core": "3.5.30",
    "@vue/tsconfig": "^0.1.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "sass": "^1.98.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^4.9.4",
    "vite": "5.2.8",
    "vitest": "^1.6.1",
    "vue-tsc": "^1.0.24",
    "weapp-tailwindcss": "^4.10.3"
  },
  "overrides": {
    "@vue/compiler-core": "3.5.30",
    "@vue/compiler-dom": "3.5.30",
    "@vue/compiler-sfc": "3.5.30",
    "@vue/compiler-ssr": "3.5.30",
    "@vue/server-renderer": "3.5.30",
    "@vue/shared": "3.5.30",
    "vue": "3.5.30"
  }
}
